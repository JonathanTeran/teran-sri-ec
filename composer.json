{
    "name": "amephia/sri-ec",
    "description": "High-performance Ecuador SRI Electronic Billing Library",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-openssl": "*",
        "ext-soap": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Teran\\Sri\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Teran\\Sri\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
